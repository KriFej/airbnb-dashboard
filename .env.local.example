# SEO — Google Search Console & Bing Webmaster Tools
# Google : Search Console → Ajouter propriété → "Balise HTML" → copier la valeur du content=""
NEXT_PUBLIC_GOOGLE_VERIFICATION=
# Bing : Bing Webmaster Tools → Mon site → Vérification → "Balise meta" → copier la valeur content=""
NEXT_PUBLIC_BING_VERIFICATION=

# Supabase — projet locpilote
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# Notifications — inscriptions & alertes
# resend.com → API Keys
RESEND_API_KEY=re_xxx
# Email qui reçoit les notifications admin (nouvelles inscriptions, etc.)
OWNER_EMAIL=hello@locpilote.com
# Make.com → optionnel, pour synchroniser vers Google Sheets
MAKE_WEBHOOK_URL=https://hook.eu2.make.com/xxx

# Lemon Squeezy — paiements & abonnements
# 1. Dashboard LS → Settings → Webhooks → Signing Secret
LEMONSQUEEZY_WEBHOOK_SECRET=xxx

# 2. Dashboard LS → Produit → Variant → "Share" → copier l'URL de checkout
LEMONSQUEEZY_CHECKOUT_STARTER=https://ton-store.lemonsqueezy.com/buy/xxx-starter
LEMONSQUEEZY_CHECKOUT_STARTER_ANNUAL=https://ton-store.lemonsqueezy.com/buy/xxx-starter-annual
LEMONSQUEEZY_CHECKOUT_PRO=https://ton-store.lemonsqueezy.com/buy/xxx-pro
LEMONSQUEEZY_CHECKOUT_PRO_ANNUAL=https://ton-store.lemonsqueezy.com/buy/xxx-pro-annual

# 3. Dashboard LS → Produit → Variants → l'ID numérique (visible dans l'URL)
LEMONSQUEEZY_VARIANT_STARTER=123456
LEMONSQUEEZY_VARIANT_STARTER_ANNUAL=123457
LEMONSQUEEZY_VARIANT_PRO=789012
LEMONSQUEEZY_VARIANT_PRO_ANNUAL=789013
